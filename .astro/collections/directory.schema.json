{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Trusted",
        "Under Review",
        "Not Verified",
        "Removed from Trusted Status"
      ]
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "domain",
    "status",
    "updatedAt"
  ]
}